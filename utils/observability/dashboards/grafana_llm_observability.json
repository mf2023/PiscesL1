{
  "__inputs": [],
  "__requires": [],
  "title": "PiscesL1 - LLM Observability",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "LLM Requests (rate)",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"expr": "sum(rate(llm_requests_total[5m]))", "legendFormat": "all"},
        {"expr": "sum by (provider,model)(rate(llm_requests_total[5m]))", "legendFormat": "{{provider}}/{{model}}"}
      ]
    },
    {
      "type": "stat",
      "title": "LLM Error Rate",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [
        {"expr": "sum(rate(llm_errors_total[5m])) / clamp_min(sum(rate(llm_requests_total[5m])), 1)"}
      ]
    },
    {
      "type": "graph",
      "title": "Latency p95 (ms)",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(llm_latency_ms_bucket[5m])))", "legendFormat": "p95"}
      ]
    },
    {
      "type": "graph",
      "title": "Tokens Per Second",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [
        {"expr": "avg(llm_tokens_per_second)", "legendFormat": "avg tps"},
        {"expr": "avg by (provider,model)(llm_tokens_per_second)", "legendFormat": "{{provider}}/{{model}}"}
      ]
    },
    {
      "type": "graph",
      "title": "Tokens (input/output/total)",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum(rate(llm_tokens_total{type=\"input\"}[5m]))", "legendFormat": "input"},
        {"expr": "sum(rate(llm_tokens_total{type=\"output\"}[5m]))", "legendFormat": "output"},
        {"expr": "sum(rate(llm_tokens_total{type=\"total\"}[5m]))", "legendFormat": "total"}
      ]
    },
    {
      "type": "graph",
      "title": "Streaming TTFT p50/p95 (ms)",
      "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (le) (rate(llm_stream_ttft_ms_bucket[5m])))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(llm_stream_ttft_ms_bucket[5m])))", "legendFormat": "p95"}
      ]
    },
    {
      "type": "graph",
      "title": "Streaming E2E Latency p95 (ms)",
      "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(llm_stream_e2e_latency_ms_bucket[5m])))", "legendFormat": "p95"}
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Errors (rate)",
      "gridPos": {"x": 0, "y": 30, "w": 8, "h": 6},
      "targets": [
        {"expr": "sum(rate(exporter_errors_total[5m]))", "legendFormat": "all"},
        {"expr": "sum by (exporter)(rate(exporter_errors_total[5m]))", "legendFormat": "{{exporter}}"}
      ]
    },
    {
      "type": "graph",
      "title": "Exporter Time Since Last Success (s)",
      "gridPos": {"x": 8, "y": 30, "w": 8, "h": 6},
      "targets": [
        {"expr": "time() - exporter_last_success_timestamp_seconds", "legendFormat": "{{exporter}}"}
      ]
    },
    {
      "type": "stat",
      "title": "Exporter Last Error (epoch)",
      "gridPos": {"x": 16, "y": 30, "w": 8, "h": 6},
      "targets": [
        {"expr": "max by (exporter) (exporter_last_error_timestamp_seconds)", "legendFormat": "{{exporter}}"}
      ]
    },
    {
      "type": "graph",
      "title": "Exporter Error Rate (5m)",
      "gridPos": {"x": 0, "y": 36, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum by (exporter) (rate(exporter_errors_total[5m]))", "legendFormat": "{{exporter}}"}
      ]
    },
    {
      "type": "graph",
      "title": "LLM Failures (by error_class)",
      "gridPos": {"x": 0, "y": 44, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (error_class) (rate(llm_failures_total[5m]))", "legendFormat": "{{error_class}}"}
      ]
    },
    {
      "type": "graph",
      "title": "LLM Finish Reasons",
      "gridPos": {"x": 12, "y": 44, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (reason) (rate(llm_finish_reason_total[5m]))", "legendFormat": "{{reason}}"}
      ]
    },
    {
      "type": "graph",
      "title": "Network Bytes/s (RX/TX)",
      "gridPos": {"x": 0, "y": 52, "w": 12, "h": 8},
      "targets": [
        {"expr": "avg(runtime_net_rx_bytes_per_sec)", "legendFormat": "rx_bps"},
        {"expr": "avg(runtime_net_tx_bytes_per_sec)", "legendFormat": "tx_bps"}
      ]
    },
    {
      "type": "graph",
      "title": "Disk Bytes/s (Read/Write)",
      "gridPos": {"x": 12, "y": 52, "w": 12, "h": 8},
      "targets": [
        {"expr": "avg(runtime_disk_read_bytes_per_sec)", "legendFormat": "read_bps"},
        {"expr": "avg(runtime_disk_write_bytes_per_sec)", "legendFormat": "write_bps"}
      ]
    },
    {
      "type": "graph",
      "title": "Disk IOPS (Read/Write)",
      "gridPos": {"x": 0, "y": 60, "w": 12, "h": 8},
      "targets": [
        {"expr": "avg(runtime_disk_read_iops)", "legendFormat": "read_iops"},
        {"expr": "avg(runtime_disk_write_iops)", "legendFormat": "write_iops"}
      ]
    },
    {
      "type": "stat",
      "title": "CPU/MEM Percent",
      "gridPos": {"x": 12, "y": 60, "w": 12, "h": 8},
      "targets": [
        {"expr": "avg(runtime_system_cpu_percent)", "legendFormat": "cpu%"},
        {"expr": "avg(runtime_system_memory_percent)", "legendFormat": "mem%"}
      ]
    },
    {
      "type": "graph",
      "title": "EWMA Latency p95/p99 (ms)",
      "gridPos": {"x": 0, "y": 68, "w": 12, "h": 8},
      "targets": [
        {"expr": "latency_ewma_p95_ms", "legendFormat": "ewma p95"},
        {"expr": "latency_ewma_p99_ms", "legendFormat": "ewma p99"}
      ]
    },
    {
      "type": "graph",
      "title": "Latency Drift (p95/p99)",
      "gridPos": {"x": 12, "y": 68, "w": 12, "h": 8},
      "targets": [
        {"expr": "latency_drift_p95", "legendFormat": "drift p95"},
        {"expr": "latency_drift_p99", "legendFormat": "drift p99"}
      ],
      "thresholds": [
        {"op": "gt", "value": 0.3, "color": "red"},
        {"op": "lt", "value": -0.3, "color": "red"}
      ]
    },
    {
      "type": "graph",
      "title": "Error Rate EWMA",
      "gridPos": {"x": 0, "y": 76, "w": 12, "h": 8},
      "targets": [
        {"expr": "error_rate_ewma", "legendFormat": "ewma err"}
      ]
    },
    {
      "type": "graph",
      "title": "Exporter Duration P95 (s)",
      "gridPos": {"x": 12, "y": 76, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, exporter) (rate(exporter_duration_seconds_bucket[5m])))", "legendFormat": "{{exporter}}"}
      ]
    },
    {
      "type": "graph",
      "title": "Collector Duration P95 (s)",
      "gridPos": {"x": 0, "y": 84, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, collector) (rate(collector_duration_seconds_bucket[5m])))", "legendFormat": "{{collector}}"}
      ]
    },
    {
      "type": "stat",
      "title": "Collector Health",
      "gridPos": {"x": 12, "y": 84, "w": 12, "h": 8},
      "targets": [
        {"expr": "avg by (collector) (collector_health)", "legendFormat": "{{collector}}"}
      ]
    }
  ],
  "version": 1
}
